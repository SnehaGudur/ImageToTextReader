@{
    ViewData["Title"] = "Image to Text OCR";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container d-flex justify-content-center align-items-center" style="min-height: 90vh;">
    <div class="card shadow-lg p-4" style="width: 100%; max-width: 700px; border-radius: 15px;">

        <!-- Header -->
        <div class="text-center mb-4">
            <h2 class="fw-bold text-primary">Image to Text OCR</h2>
            <p class="text-muted">Upload an image and extract text instantly</p>
        </div>

        <!-- Upload Form -->
        <form method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label fw-semibold">Select Image</label>
                <input type="file" name="imageFile" class="form-control" accept="image/*" required />
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">
                    Upload & Extract Text
                </button>
            </div>
        </form>

        <!-- OCR Result -->
        @if (ViewBag.Result != null)
        {
            <hr class="my-4" />

            <div>
                <h5 class="fw-bold mb-2">Extracted Text</h5>
                <textarea class="form-control" rows="8" readonly
                          style="background-color: #f8f9fa;">@ViewBag.Result</textarea>
            </div>

            <!-- Download Button -->
            <div class="d-grid mt-3">
                <form asp-action="DownloadExcel" method="get">
                    <button type="submit" class="btn btn-success btn-lg">
                        Download Excel
                    </button>
                </form>
            </div>
        }
    </div>
</div>